# MaoDien Environment Configuration
# Copy this file to .env and fill in the actual values

# Application Configuration
APP_PORT=8083
APP_NAME=MaoDien API
SPRING_PROFILES_ACTIVE=production

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-must-be-at-least-32-characters-long
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# Database Configuration (PostgreSQL)
POSTGRES_DB=maodien
POSTGRES_USER=maodien
POSTGRES_PASSWORD=your-secure-database-password
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Google OAuth2 Configuration
GOOGLE_OAUTH2_CLIENT_ID=your-google-oauth2-client-id
GOOGLE_OAUTH2_CLIENT_SECRET=your-google-oauth2-client-secret
GOOGLE_OAUTH2_REDIRECT_URI=https://your-domain.com/login/oauth2/code/google

# Server Configuration
SERVER_PORT=8083
FRONTEND_URL=https://your-frontend-domain.com
OAUTH_SUCCESS_REDIRECT_PATH=/oauth/callback

# JPA/Hibernate Configuration
DDL_AUTO=update
SHOW_SQL=false
FORMAT_SQL=false

# Development specific overrides (uncomment for development)
# SPRING_PROFILES_ACTIVE=development
# GOOGLE_OAUTH2_REDIRECT_URI=http://localhost:8083/login/oauth2/code/google
# FRONTEND_URL=http://localhost:3000
# SHOW_SQL=true
# FORMAT_SQL=true

# Security Configuration
RBAC_ENABLED=false

# Audit Logging Configuration
AUDIT_ENABLED=true
AUDIT_LOG_PARAMETERS=false
AUDIT_LOG_RESPONSE=false
AUDIT_LOG_ONLY_SUCCESS=false
AUDIT_MAX_VALUE_LENGTH=10000
AUDIT_ASYNC_LOGGING=true
AUDIT_RETENTION_DAYS=365
AUDIT_COMPRESS_OLD_LOGS=true

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_LOGIN_REQUESTS_PER_MINUTE=10
RATE_LIMIT_REGISTER_REQUESTS_PER_MINUTE=5
RATE_LIMIT_REFRESH_TOKEN_REQUESTS_PER_MINUTE=30
RATE_LIMIT_ANONYMOUS_REQUESTS_PER_MINUTE=50
RATE_LIMIT_BAN_DURATION_MINUTES=15
RATE_LIMIT_MAX_VIOLATIONS_BEFORE_BAN=5

